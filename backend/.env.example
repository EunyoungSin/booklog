# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=booklog

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Email (SMTP) - leave SMTP_HOST blank in dev to log verification codes instead of sending them
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@booklog.local
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=10
EMAIL_VERIFICATION_COMPLETION_WINDOW_MINUTES=30
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Aladin (알라딘 오픈API) - https://www.aladin.co.kr/ttb/apiguide.aspx
ALADIN_TTB_KEY=your-ttb-key
ALADIN_API_BASE_URL=https://www.aladin.co.kr/ttb/api

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-lite-latest
